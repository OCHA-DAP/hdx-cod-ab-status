{
  "name": "my-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run fetch && astro build",
    "fetch": "npm run fetch:m49 && npm run fetch:arcgis && npm run fetch:plans && npm run fetch:regions && npm run fetch:offices",
    "fetch:m49": "node scripts/m49.mjs",
    "fetch:arcgis": "node scripts/arcgis.mjs",
    "fetch:plans": "node scripts/plans.mjs",
    "fetch:regions": "node scripts/regions.mjs",
    "fetch:offices": "node scripts/offices.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "update": "npx npm-check-updates -u && npm install",
    "sync": "sh sync-data.sh"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "astro": "^6.1.5",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "papaparse": "^5.5.3"
  }
}
