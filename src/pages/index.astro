---
import CycleOverview from "../components/CycleOverview.astro";
import PriorBacklogSections from "../components/PriorBacklogSections.astro";
import CurrentCycleSection from "../components/CurrentCycleSection.astro";
import PreparednessSection from "../components/PreparednessSection.astro";
import { loadData } from "../lib/loadData.ts";
import "../styles/base.css";

const data = loadData();
const priorYears = data.yearStats.filter((y) => y.year !== data.latestYear);
const syncedAtFormatted = data.syncedAt
  ? new Date(data.syncedAt).toLocaleDateString("en-GB", {
      day: "numeric",
      month: "long",
      year: "numeric",
      timeZone: "UTC",
    })
  : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <title>COD-AB Activity Tracker</title>
  </head>
  <body>
    <div class="page">
      <header>
        <h1>COD-AB Activity Tracker</h1>
        <p class="subtitle">
          {data.total} work orders across {data.yearStats.length} cycle{
            data.yearStats.length !== 1 ? "s" : ""
          }
        </p>
        {syncedAtFormatted && <p class="last-synced">Last synced: {syncedAtFormatted}</p>}
        <p class="update-schedule">Updates weekly on Wednesday mornings</p>
      </header>

      <nav class="tab-bar">
        <button class="tab-btn active" data-tab="work-orders">
          <span class="tab-title">Work Orders</span>
          <span class="tab-desc">Pipeline &amp; status tracking</span>
        </button>
        <button class="tab-btn" data-tab="coverage">
          <span class="tab-title">Coverage</span>
          <span class="tab-desc">Plan &amp; preparedness gaps</span>
        </button>
      </nav>

      <!-- ── Tab 1: Work Orders ─────────────────────────────────── -->
      <div id="work-orders" class="tab-panel">
        <CycleOverview yearStats={data.yearStats} latestYear={data.latestYear} />

        <PriorBacklogSections
          priorYears={priorYears}
          backlog={data.backlog}
          backlogByQuarter={data.backlogByQuarter}
        />

        <CurrentCycleSection
          latestYear={data.latestYear}
          currentCycleWork={data.currentCycleWork}
          currentByQuarter={data.currentByQuarter}
        />
      </div>

      <!-- ── Tab 2: Coverage ────────────────────────────────────── -->
      <div id="coverage" class="tab-panel" hidden>
        <PreparednessSection planGroups={data.planGroups} />
      </div>

      <footer>
        <span>Download:</span>
        <span class="footer-group">
          <span class="group-label">Managed</span>
          <a href={`${import.meta.env.BASE_URL}/data/work.csv`}>Work orders</a>
          <a href={`${import.meta.env.BASE_URL}/data/reviews.csv`}>Reviews</a>
        </span>
        <span class="footer-group">
          <span class="group-label">External</span>
          <a href={`${import.meta.env.BASE_URL}/api/plans.csv`}>Plans</a>
          <a href={`${import.meta.env.BASE_URL}/api/regions.csv`}>Regions</a>
          <a href={`${import.meta.env.BASE_URL}/api/offices.csv`}>Offices</a>
          <a href={`${import.meta.env.BASE_URL}/api/gis.csv`}>GIS</a>
          <a href={`${import.meta.env.BASE_URL}/api/m49.csv`}>M49</a>
        </span>
      </footer>
    </div>

    <script>
      const btns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
      const panels = document.querySelectorAll<HTMLElement>(".tab-panel");
      btns.forEach((btn) => {
        btn.addEventListener("click", () => {
          btns.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const target = btn.dataset.tab;
          panels.forEach((p) => {
            p.hidden = p.id !== target;
          });
        });
      });
    </script>
  </body>
</html>

<style>
  /* ── Tabs ───────────────────────────────────────────────────── */
  .tab-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .tab-btn {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    padding: 0.75rem 1.25rem;
    flex: 1;
    background: none;
    border: 2px solid #e2e5ea;
    border-radius: 6px;
    cursor: pointer;
    text-align: left;
  }

  .tab-btn.active {
    border-color: #3b82f6;
    background: #eff6ff;
  }

  .tab-btn:hover:not(.active) {
    border-color: #93c5fd;
  }

  .tab-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  .tab-desc {
    font-size: 0.75rem;
    color: #666;
  }

  .tab-panel[hidden] {
    display: none;
  }

  footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e5ea;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.8rem;
    color: #666;
  }

  footer a {
    color: #3b82f6;
    text-decoration: none;
  }

  footer a:hover {
    text-decoration: underline;
  }

  .footer-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-group + .footer-group {
    border-left: 1px solid #e2e5ea;
    padding-left: 0.5rem;
  }

  .group-label {
    font-weight: 600;
    color: #444;
  }
</style>
