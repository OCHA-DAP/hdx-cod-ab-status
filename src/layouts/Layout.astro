---
import { ClientRouter } from "astro:transitions";
import "../styles/base.css";

interface Props {
  syncedAtFormatted: string | null;
  openTotal: number;
  totalInGis: number;
  totalLocations: number;
}

const { syncedAtFormatted, openTotal, totalInGis, totalLocations } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

const pathname = Astro.url.pathname;
const isCoverage = pathname.endsWith("/coverage");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>COD-AB Status Dashboard</title>
    <ClientRouter />
  </head>
  <body>
    <div class="page">
      <header>
        <h1>COD-AB Status Dashboard</h1>
        <p class="update-schedule">Work order data updated weekly on Wednesdays</p>
        {syncedAtFormatted && <p class="last-synced">Last synced: {syncedAtFormatted}</p>}
      </header>

      <nav class="tab-bar">
        <a href={base} class:list={["tab-btn", { active: !isCoverage }]}>
          <span class="tab-left">
            <span class="tab-title">Work Orders</span>
            <span class="tab-desc">Pipeline &amp; status tracking</span>
          </span>
          <span class="tab-count">{openTotal}<span class="tab-denom"> open</span></span>
        </a>
        <a href={`${base}coverage`} class:list={["tab-btn", { active: isCoverage }]}>
          <span class="tab-left">
            <span class="tab-title">Coverage</span>
            <span class="tab-desc">Plan &amp; preparedness gaps</span>
          </span>
          <span class="tab-count">{totalInGis}<span class="tab-denom">/{totalLocations}</span></span
          >
        </a>
      </nav>

      <div transition:animate="none">
        <slot />
      </div>

      <footer>
        <span>Download:</span>
        <span class="footer-group">
          <span class="group-label">SharePoint</span>
          <a href={`${base}data/work.csv`}>Work orders</a>
          <a href={`${base}data/reviews.csv`}>Reviews</a>
        </span>
        <span class="footer-group">
          <span class="group-label">ArcGIS</span>
          <a href={`${base}api/gis.csv`}>Locations</a>
          <a href={`${base}api/cod_metadata.csv`}>Metadata</a>
        </span>
        <span class="footer-group">
          <span class="group-label">External</span>
          <a href={`${base}api/hdx.csv`}>HDX</a>
          <a href={`${base}api/m49.csv`}>M49</a>
          <a href={`${base}api/plans.csv`}>Plans</a>
          <a href={`${base}api/offices.csv`}>Offices</a>
          <a href={`${base}api/regions.csv`}>Regions</a>
        </span>
      </footer>
    </div>
  </body>
</html>


<script>
  function updateActiveTabs() {
    const isCoverage =
      window.location.pathname.endsWith("/coverage") ||
      window.location.pathname.endsWith("/coverage/");
    document.querySelectorAll<HTMLAnchorElement>(".tab-btn").forEach((btn) => {
      const href = btn.getAttribute("href") ?? "";
      const btnIsCoverage = href.endsWith("coverage") || href.endsWith("coverage/");
      btn.classList.toggle("active", btnIsCoverage === isCoverage);
    });
  }

  document.addEventListener("astro:page-load", updateActiveTabs);
</script>

<style>
  /* ── Tabs ───────────────────────────────────────────────────── */
  .tab-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .tab-btn {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    flex: 1;
    background: none;
    border: 2px solid #e2e5ea;
    border-radius: 6px;
    cursor: pointer;
    text-align: left;
    text-decoration: none;
    color: inherit;
  }

  .tab-left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .tab-count {
    font-size: 1.4rem;
    font-weight: 700;
    color: #3b82f6;
    line-height: 1;
    white-space: nowrap;
  }

  .tab-btn:not(.active) .tab-count {
    color: #9ca3af;
  }

  .tab-denom {
    font-size: 0.75em;
    font-weight: 500;
    opacity: 0.6;
  }

  .tab-btn.active {
    border-color: #3b82f6;
    background: #eff6ff;
  }

  .tab-btn:hover:not(.active) {
    border-color: #93c5fd;
  }

  .tab-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  .tab-desc {
    font-size: 0.75rem;
    color: #666;
  }

  footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e5ea;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.8rem;
    color: #666;
  }

  footer a {
    color: #3b82f6;
    text-decoration: none;
  }

  footer a:hover {
    text-decoration: underline;
  }

  .footer-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-group + .footer-group {
    border-left: 1px solid #e2e5ea;
    padding-left: 0.5rem;
  }

  .group-label {
    font-weight: 600;
    color: #444;
  }
</style>
