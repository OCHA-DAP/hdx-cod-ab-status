---
import type { ScheduleGroup } from "../lib/loadData.ts";
import { statusClass, statusLabel } from "../lib/status.ts";

interface Props {
  groups: ScheduleGroup[];
}

const { groups } = Astro.props;

function ageLabel(createdDate: string, endDate?: string): string | null {
  if (!createdDate) return null;
  const created = new Date(createdDate + "T00:00:00");
  const end = endDate ? new Date(endDate + "T00:00:00") : new Date();
  const days = Math.floor((end.getTime() - created.getTime()) / (1000 * 60 * 60 * 24));
  if (days > 31) {
    const months = days / 30.44;
    const formatted = months < 2 ? months.toFixed(1) : Math.round(months).toString();
    return `${formatted} months`;
  }
  return `${days} day${days === 1 ? "" : "s"}`;
}

function ageTooltip(createdDate: string, publicationDate?: string): string | null {
  if (!createdDate) return null;
  const fmt = (d: string) =>
    new Date(d + "T00:00:00")
      .toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "2-digit" })
      .replace("Sept", "Sep");
  if (publicationDate)
    return `${fmt(createdDate)}  (created)\n${fmt(publicationDate)}  (published)`;
  return `${fmt(createdDate)}  (created)`;
}
---

{
  groups.map((group) => (
    <Fragment>
      <h3 class="quarter-heading">
        {group.quarter}
        {(() => {
          const remaining = group.rows.filter((r) => r.work_order_status !== "published").length;
          return remaining > 0 ? <span class="count-chip">{remaining} remaining</span> : null;
        })()}
      </h3>
      <table>
        <colgroup>
          <col style="width: 30%" />
          <col style="width: 5.5em" />
          <col style="width: 15%" />
          <col style="width: 11%" />
          <col style="width: 15%" />
          <col style="width: 11%" />
          <col style="width: 15%" />
        </colgroup>
        <thead>
          <tr>
            <th>Location</th>
            <th title="Update type (major / minor)">Major</th>
            <th>Status</th>
            <th>Open For</th>
            <th>Plan Type</th>
            <th>Office Type</th>
            <th>Regional Office</th>
          </tr>
        </thead>
        <tbody>
          {group.rows.map((row) => (
            <tr>
              <td>
                {row.name_en} <span class="iso3">{row.iso3}</span>
              </td>
              <td style="text-align: center">
                {row.update_type === "major" ? (
                  <span class="upd-icon upd-major" title="Major update">
                    ●
                  </span>
                ) : row.update_type === "minor" ? (
                  <span class="upd-icon upd-minor" title="Minor update">
                    ○
                  </span>
                ) : null}
              </td>
              <td>
                <span class={`badge ${statusClass(row.work_order_status)}`}>
                  {statusLabel(row.work_order_status)}
                </span>
              </td>
              <td>
                {(() => {
                  const label = ageLabel(row.created_date, row.publication_date || undefined);
                  const tip = ageTooltip(row.created_date, row.publication_date || undefined);
                  return label ? <span title={tip ?? undefined}>{label}</span> : "—";
                })()}
              </td>
              <td>{row.plan_type || "—"}</td>
              <td>{row.office_type || "—"}</td>
              <td>{row.regional || "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </Fragment>
  ))
}
