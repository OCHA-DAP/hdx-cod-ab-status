---
import type { ScheduleGroup, WorkOrderRow } from "../lib/loadData.ts";
import WorkOrderTable from "./WorkOrderTable.astro";

interface Props {
  latestYear: string;
  currentCycleWork: WorkOrderRow[];
  currentByQuarter: ScheduleGroup[];
}

const { latestYear, currentCycleWork, currentByQuarter } = Astro.props;
---

<section>
  <h2>
    {latestYear} Work Orders
    <span class="count-chip">{currentCycleWork.length} total</span>
  </h2>
  <p class="section-desc">
    All work orders in the {latestYear} cycle, grouped by planned delivery quarter.
  </p>

  {
    currentByQuarter.length === 0 ? (
      <p class="empty">No active work orders in the {latestYear} cycle yet.</p>
    ) : (
      <WorkOrderTable groups={currentByQuarter} />
    )
  }
</section>
