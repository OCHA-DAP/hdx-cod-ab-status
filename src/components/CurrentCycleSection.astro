---
import type { ReviewGapRow, ScheduleGroup, WorkOrderRow } from "../lib/loadData.ts";
import GapTable from "./GapTable.astro";
import Term from "./Term.astro";
import WorkOrderTable from "./WorkOrderTable.astro";

interface Props {
  latestYear: string;
  currentCycleWork: WorkOrderRow[];
  currentByQuarter: ScheduleGroup[];
  gapRows: ReviewGapRow[];
}

const { latestYear, currentCycleWork, currentByQuarter, gapRows } = Astro.props;
const remaining = currentCycleWork.filter((r) => r.work_order_status !== "published").length;
const totalRemaining = remaining + gapRows.length;
---

<section>
  <h2>
    {latestYear}
    <Term term="work-order">Work Orders</Term>
    <span class={`count-chip ${totalRemaining === 0 ? "done" : ""}`}>
      {totalRemaining === 0 ? "All published" : `${totalRemaining} remaining`}
    </span>
  </h2>
  <p class="section-desc">
    All work orders in the {latestYear}
    <Term term="cycle">cycle</Term>, grouped by{" "}
    <Term term="planned-quarter">planned delivery quarter</Term>.
  </p>

  {
    currentByQuarter.length === 0 ? (
      <p class="empty">No active work orders in the {latestYear} cycle yet.</p>
    ) : (
      <WorkOrderTable groups={currentByQuarter} />
    )
  }
  <GapTable rows={gapRows} />
</section>
