---
import type { PlanGroup } from "../lib/loadData.ts";

interface Props {
  planGroups: PlanGroup[];
}

const { planGroups } = Astro.props;
---

{
  planGroups.map((group) => (
    <section>
      <h2>
        {group.label}
        <span class="count-chip">{group.countries.length}</span>
      </h2>

      {group.countries.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Country</th>
              <th>Plan Types</th>
              {group.key === "prior_only" && <th>Years</th>}
              <th>Office Type</th>
              <th>Regional Office</th>
              <th>In ArcGIS</th>
            </tr>
          </thead>
          <tbody>
            {group.countries.map((row) => (
              <tr class={row.inArcgis ? "" : "row-gap"}>
                <td>
                  {row.name_en} <span class="iso3">{row.iso3}</span>
                </td>
                <td>{row.plan_types.join(" / ") || "—"}</td>
                {group.key === "prior_only" && <td>{row.year_range ?? "—"}</td>}
                <td>{row.office_type || "—"}</td>
                <td>{row.regional || "—"}</td>
                <td class={row.inArcgis ? "flag-yes" : "flag-no"}>
                  {row.inArcgis ? "Yes" : "No"}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="empty">No countries found.</p>
      )}
    </section>
  ))
}

<style>
  .flag-no {
    color: #b45309;
    font-weight: 600;
  }
</style>
