---
import type { PlanGroup } from "../lib/loadData.ts";

interface Props {
  planGroups: PlanGroup[];
}

const { planGroups } = Astro.props;
---

{
  planGroups.map((group) => (
    <section id={group.key}>
      <h2>
        {group.label}
        {(() => {
          const missing = group.countries.filter((c) => !c.inGis).length;
          return missing > 0 ? (
            <span class="count-chip warn">{missing} missing</span>
          ) : (
            <span class="count-chip done">All in GIS</span>
          );
        })()}
      </h2>

      {group.countries.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Location</th>
              <th>Plan Types</th>
              {group.key === "prior_only" && <th>Years</th>}
              <th>Office Type</th>
              <th>Regional Office</th>
              <th>In GIS</th>
              <th style="width: 10rem">Next Review</th>
            </tr>
          </thead>
          <tbody>
            {group.countries.map((row) => (
              <tr class={row.inGis ? "" : "row-gap"}>
                <td>
                  {row.name_en} <span class="iso3">{row.iso3}</span>
                </td>
                <td>{row.plan_types.join(" / ") || "—"}</td>
                {group.key === "prior_only" && <td>{row.year_range ?? "—"}</td>}
                <td>{row.office_type || "—"}</td>
                <td>{row.regional || "—"}</td>
                <td class={row.inGis ? "flag-yes" : "flag-no"}>{row.inGis ? "Yes" : "No"}</td>
                <td class={row.review_overdue ? "flag-no" : ""}>
                  <span title={row.next_review_date}>{row.next_review_relative ?? "—"}</span>
                  {row.open_work_order_status && (
                    <span class={`wo-badge wo-${row.open_work_order_status}`}>
                      {row.open_work_order_status.charAt(0).toUpperCase() +
                        row.open_work_order_status.slice(1)}
                    </span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="empty">No locations found.</p>
      )}
    </section>
  ))
}

<style>
  .flag-no {
    color: #b45309;
    font-weight: 600;
  }

  .wo-badge {
    display: inline-block;
    margin-left: 0.4em;
    padding: 0.1em 0.45em;
    border-radius: 3px;
    font-size: 0.75em;
    font-weight: 600;
    vertical-align: middle;
    background: #e5e7eb;
    color: #374151;
  }

  .wo-badge.wo-processing {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .wo-badge.wo-feedback {
    background: #fef9c3;
    color: #92400e;
  }

  .wo-badge.wo-initialized {
    background: #f3f4f6;
    color: #6b7280;
  }

  .wo-badge.wo-blocked {
    background: #fee2e2;
    color: #b91c1c;
  }
</style>
