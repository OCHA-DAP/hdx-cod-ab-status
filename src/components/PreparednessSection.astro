---
import type { PlanGroup } from "../lib/loadData.ts";
import Term from "./Term.astro";
import type { TermSlug } from "../lib/glossary.ts";

interface Props {
  planGroups: PlanGroup[];
}

const { planGroups } = Astro.props;
---

{
  planGroups.map((group) => (
    <section id={group.key}>
      <h2>
        <Term term={group.key as TermSlug}>{group.label}</Term>
        {(() => {
          const missing = group.countries.filter((c) => !c.inGis).length;
          return missing > 0 ? (
            <span class="count-chip warn">{missing} missing</span>
          ) : (
            <span class="count-chip done">All in GIS</span>
          );
        })()}
      </h2>

      {group.countries.length > 0 ? (
        <table>
          {group.key === "prior-plans" ? (
            <colgroup>
              <col style="width: 23%" />
              <col style="width: 12%" />
              <col style="width: 11%" />
              <col style="width: 10%" />
              <col style="width: 12%" />
              <col style="width: 7%" />
              <col style="width: 13%" />
              <col style="width: 12%" />
            </colgroup>
          ) : (
            <colgroup>
              <col style="width: 26%" />
              <col style="width: 13%" />
              <col style="width: 11%" />
              <col style="width: 13%" />
              <col style="width: 8%" />
              <col style="width: 16%" />
              <col style="width: 13%" />
            </colgroup>
          )}
          <thead>
            <tr>
              <th>Location</th>
              <th>
                <Term term="plan-type">Plan Types</Term>
              </th>
              {group.key === "prior-plans" && <th>Years</th>}
              <th>
                <Term term="office-type">Office Type</Term>
              </th>
              <th>
                <Term term="regional-office">Regional Office</Term>
              </th>
              <th>
                <Term term="in-gis">In GIS</Term>
              </th>
              <th>
                <Term term="next-review">Next Review</Term>
              </th>
              <th>
                <Term term="work-order" align="right">
                  Work Order
                </Term>
              </th>
            </tr>
          </thead>
          <tbody>
            {group.countries.map((row) => (
              <tr class={row.inGis ? "" : "row-gap"}>
                <td>
                  {row.hdxUrl ? (
                    <a href={row.hdxUrl} target="_blank" rel="noopener">
                      {row.name_en}
                    </a>
                  ) : (
                    row.name_en
                  )}{" "}
                  <span class="iso3">{row.iso3}</span>
                </td>
                <td>{row.plan_types.join(" / ") || "—"}</td>
                {group.key === "prior-plans" && <td>{row.year_range ?? "—"}</td>}
                <td>{row.office_type || "—"}</td>
                <td>{row.regional || "—"}</td>
                <td class={row.inGis ? "flag-yes" : "flag-no"}>{row.inGis ? "Yes" : "No"}</td>
                <td class={row.review_overdue ? "flag-no" : ""}>
                  <span title={row.next_review_date}>{row.next_review_relative ?? "—"}</span>
                </td>
                <td>
                  {row.open_work_order_status ? (
                    <Term term={`status-${row.open_work_order_status}` as TermSlug} align="right">
                      <span class={`wo-badge wo-${row.open_work_order_status}`}>
                        {row.open_work_order_status.charAt(0).toUpperCase() +
                          row.open_work_order_status.slice(1)}
                      </span>
                    </Term>
                  ) : row.review_gap ? (
                    <Term term="gap-coverage" align="right">
                      <span class="wo-badge wo-gap">No WO</span>
                    </Term>
                  ) : (
                    "—"
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="empty">No locations found.</p>
      )}
    </section>
  ))
}

<style>
  section {
    scroll-margin-top: 0.75rem;
  }

  .flag-no {
    color: #b45309;
    font-weight: 600;
  }

  .wo-badge {
    display: inline-block;
    margin-left: 0.4em;
    padding: 0.1em 0.45em;
    border-radius: 3px;
    font-size: 0.75em;
    font-weight: 600;
    vertical-align: middle;
    background: #e5e7eb;
    color: #374151;
  }

  .wo-badge.wo-processing {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .wo-badge.wo-feedback {
    background: #fef9c3;
    color: #92400e;
  }

  .wo-badge.wo-initialized {
    background: #f3f4f6;
    color: #6b7280;
  }

  .wo-badge.wo-blocked {
    background: #fee2e2;
    color: #b91c1c;
  }

  .wo-badge.wo-gap {
    background: #ffedd5;
    color: #9a3412;
  }
</style>
