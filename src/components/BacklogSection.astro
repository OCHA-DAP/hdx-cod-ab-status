---
import type { ReviewGapRow, ScheduleGroup } from "../lib/loadData.ts";
import Term from "./Term.astro";
import WorkOrderTable from "./WorkOrderTable.astro";

interface Props {
  year: string;
  backlogCount: number;
  groups: ScheduleGroup[];
  gapRows: ReviewGapRow[];
}

const { year, backlogCount, groups, gapRows } = Astro.props;
---

<section>
  <h2>
    {year}
    <Term term="backlog">Backlog</Term>
    <span class={`count-chip ${backlogCount === 0 && gapRows.length === 0 ? "done" : "warn"}`}>
      {
        backlogCount === 0 && gapRows.length === 0
          ? "All published"
          : `${backlogCount + gapRows.length} remaining`
      }
    </span>
  </h2>
  <p class="section-desc">
    Incomplete items from the {year} cycle — work orders still in progress and locations expecting changes
    with no work order yet.
  </p>
  {backlogCount > 0 && <WorkOrderTable groups={groups} />}
  {
    gapRows.length > 0 && (
      <Fragment>
        <h3 class="quarter-heading">
          <Term term="gap-backlog">No Work Order</Term>
        </h3>
        <table>
          <colgroup>
            <col style="width: 30%" />
            <col style="width: 22%" />
            <col style="width: 18%" />
            <col style="width: 30%" />
          </colgroup>
          <thead>
            <tr>
              <th>Location</th>
              <th>
                <Term term="plan-type">Plan Type</Term>
              </th>
              <th>
                <Term term="office-type">Office Type</Term>
              </th>
              <th>
                <Term term="regional-office" align="right">
                  Regional Office
                </Term>
              </th>
            </tr>
          </thead>
          <tbody>
            {gapRows.map((row) => (
              <tr>
                <td>
                  {row.hdxUrl ? (
                    <a href={row.hdxUrl} target="_blank" rel="noopener">
                      {row.name_en}
                    </a>
                  ) : (
                    row.name_en
                  )}{" "}
                  <span class="iso3">
                    <Term term="iso3">{row.iso3}</Term>
                  </span>
                </td>
                <td>{row.plan_type || "—"}</td>
                <td>{row.office_type || "—"}</td>
                <td>{row.regional || "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </Fragment>
    )
  }
  {
    backlogCount === 0 && gapRows.length === 0 && (
      <p class="empty">All {year} work orders have been published.</p>
    )
  }
</section>
