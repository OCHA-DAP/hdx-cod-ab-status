---
import type { YearStat, WorkOrderRow, ScheduleGroup, ReviewGapRow } from "../lib/loadData.ts";
import BacklogSection from "./BacklogSection.astro";

interface Props {
  priorYears: YearStat[];
  backlog: WorkOrderRow[];
  backlogByQuarter: ScheduleGroup[];
  reviewGapsByYear: Record<string, ReviewGapRow[]>;
}

const { priorYears, backlog, backlogByQuarter, reviewGapsByYear } = Astro.props;
---

{
  priorYears.map((ys) => {
    const yearBacklog = backlog.filter((r) => r.year === ys.year);
    const yearGroups = backlogByQuarter
      .filter((g) => g.rows.some((r) => r.year === ys.year))
      .map((g) => ({ quarter: g.quarter, rows: g.rows.filter((r) => r.year === ys.year) }));
    const gapRows = reviewGapsByYear[ys.year] ?? [];
    return (
      <BacklogSection
        year={ys.year}
        backlogCount={yearBacklog.filter((r) => r.work_order_status !== "published").length}
        groups={yearGroups}
        gapRows={gapRows}
      />
    );
  })
}
