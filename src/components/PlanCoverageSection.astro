---
import type { PlanCoverageYear } from "../lib/loadData.ts";
import { statusClass, statusLabel, STATUS_TERMS } from "../lib/status.ts";
import Term from "./Term.astro";
import type { TermSlug } from "../lib/glossary.ts";

interface Props {
  planCoverageByYear: PlanCoverageYear[];
}

const { planCoverageByYear } = Astro.props;
---

{
  planCoverageByYear.map((pcg) => (
    <section>
      <h2>
        <Term term="plan-coverage">HRP / FA Plan Coverage</Term> — {pcg.year}
        {pcg.gapCount > 0 ? (
          <span class="count-chip warn">
            <Term term="gap-coverage">
              {pcg.gapCount} gap{pcg.gapCount !== 1 ? "s" : ""}
            </Term>
          </span>
        ) : (
          <span class="count-chip done">Fully covered</span>
        )}
      </h2>
      <p class="section-desc">
        All locations with an active HRP or Flash Appeal plan for {pcg.year}. Highlighted rows have
        no work order assigned.
      </p>

      <table>
        <thead>
          <tr>
            <th>Location</th>
            <th>
              <Term term="plan-type">Plan Type</Term>
            </th>
            <th>
              <Term term="change-expected">Change Expected</Term>
            </th>
            <th>
              <Term term="pipeline">Work Order Status</Term>
            </th>
            <th>
              <Term term="planned-quarter">Planned Quarter</Term>
            </th>
            <th>
              <Term term="regional-office" align="right">
                Regional Office
              </Term>
            </th>
          </tr>
        </thead>
        <tbody>
          {pcg.rows.map((row) => (
            <tr class={!row.work_order_status && row.change_expected ? "row-gap" : ""}>
              <td>
                {row.hdxUrl ? (
                  <a href={row.hdxUrl} target="_blank" rel="noopener">
                    {row.name_en}
                  </a>
                ) : (
                  row.name_en
                )}{" "}
                <span class="iso3">{row.iso3}</span>
              </td>
              <td>{row.plan_types}</td>
              <td class={row.change_expected ? "flag-yes" : ""}>
                {row.change_expected ? "Yes" : "No"}
              </td>
              <td>
                {row.work_order_status ? (
                  <Term term={STATUS_TERMS[row.work_order_status] as TermSlug}>
                    <span class={`badge ${statusClass(row.work_order_status)}`}>
                      {statusLabel(row.work_order_status)}
                    </span>
                  </Term>
                ) : (
                  <Term term="gap-coverage">
                    <span class="badge s-none">No work order</span>
                  </Term>
                )}
              </td>
              <td>{row.planned_quarter || "—"}</td>
              <td>{row.regional || "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))
}
